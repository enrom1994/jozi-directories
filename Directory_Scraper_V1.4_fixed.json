      "id": "node-gh-get",
      "name": "GitHub \u2013 GET Current File",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2464, 160]
    },
    {
      "parameters": {
        "jsCode": "const batch  = $('Code \u2013 Format Ingest Batch').first().json;\nconst ghFile = $input.first().json;\nlet existing = [], sha = null;\nif (ghFile.content) {\n  try {\n    const raw = Buffer.from(ghFile.content.replace(/\\n/g, ''), 'base64').toString('utf-8');\n    existing = JSON.parse(raw);\n    sha = ghFile.sha ?? null;\n  } catch(e) { existing = []; sha = null; }\n}\nconst existingIds = new Set(existing.map(r => r._place_id).filter(Boolean));\nconst toAdd = batch.listings.filter(r => r._place_id && !existingIds.has(r._place_id));\nconst merged = [...existing, ...toAdd];\nconst encoded = Buffer.from(JSON.stringify(merged, null, 2) + '\\n').toString('base64');\nreturn [{ json: {\n  niche_slug: batch.niche_slug, sha, content: encoded,\n  added: toAdd.length, total: merged.length,\n  message: 'chore(data): add ' + toAdd.length + ' listings to ' + batch.niche_slug + '.json [n8n]',\n  githubToken: batch.githubToken, githubRepo: batch.githubRepo, githubBranch: batch.githubBranch,\n} }];"
      },
