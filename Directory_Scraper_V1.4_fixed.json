      "parameters": {
        "jsCode": "const allRows = $input.all();\nconst pending = allRows.find(item => String(item.json['status'] ?? '').trim().toLowerCase() === 'pending');\nif (!pending) throw new Error('No pending rows in Scrape Queue.');\nconst row = pending.json;\nconst nicheSlug = String(row['niche_name'] ?? '').trim().toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');\nreturn [{ json: {\n  niche_name:  String(row['niche_name']  ?? '').trim(),\n  niche_slug:  nicheSlug,\n  search_term: String(row['search_term'] ?? '').trim(),\n  location:    String(row['location']    ?? '').trim(),\n  row_number:  row['row_number'],\n  serpApiKey:  process.env.SERP_API_KEY ?? '',\n} }];"
      },
