    {
      "parameters": {
        "jsCode": "// Webhook path: find the pending queue row matching niche_name + location.\n// Returns row_number + timestamps if found, [] if no match (skips mark-done cleanly).\nconst ctx = $('Code \u2013 Normalise Webhook Input').first()?.json ?? {};\nconst ctxNiche = String(ctx.niche_name ?? '').trim().toLowerCase();\nconst ctxLoc   = String(ctx.location   ?? '').trim().toLowerCase();\n\nconst allRows = $input.all();\nconst match = allRows.find(item => {\n  const rowNiche  = String(item.json['niche_name'] ?? '').trim().toLowerCase();\n  const rowLoc    = String(item.json['location']   ?? '').trim().toLowerCase();\n  const rowStatus = String(item.json['status']     ?? '').trim().toLowerCase();\n  return rowNiche === ctxNiche && rowLoc === ctxLoc && rowStatus === 'pending';\n});\n\nif (!match) return [];\n\nreturn [{ json: {\n  row_number: match.json['row_number'],\n  scraped_at: new Date().toISOString(),\n  status: 'done'\n} }];"
      },
