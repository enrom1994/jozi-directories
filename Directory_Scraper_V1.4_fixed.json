    {
      "parameters": {
        "jsCode": "const newListings = $('Code \u2013 Deduplicate by URL').all().map(i => i.json);\nif (newListings.length === 0) return [];\nconst nicheSlug = (newListings[0]?.niche ?? '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');\nconst githubToken  = process.env.GITHUB_TOKEN  ?? '';\nconst githubRepo   = process.env.GITHUB_REPO   ?? '';\nconst githubBranch = process.env.GITHUB_BRANCH ?? 'main';\nreturn [{ json: { niche_slug: nicheSlug, listings: newListings, count: newListings.length, githubToken, githubRepo, githubBranch } }];"
      },
