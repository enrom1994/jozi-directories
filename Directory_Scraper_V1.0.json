      "parameters": {
        "jsCode": "const allRows = $input.all();\n\n// Find first row where status is exactly 'pending'\nconst pending = allRows.find(item => {\n  const status = String(item.json['status'] ?? '').trim().toLowerCase();\n  return status === 'pending';\n});\n\nif (!pending) {\n  throw new Error('No pending rows in Scrape Queue. All rows are done or errored.');\n}\n\nconst row = pending.json;\n\nreturn [{\n  json: {\n    niche_name:  String(row['niche_name']  ?? '').trim(),\n    search_term: String(row['search_term'] ?? '').trim(),\n    location:    String(row['location']    ?? '').trim(),\n    row_number:  row['row_number'],\n    serpApiKey:  $vars.SERP_API_KEY,\n  }\n}];"
