    {
      "parameters": {
        "jsCode": "const batch = $('Code – Format Ingest Batch').first().json;\nconst ghFile = $input.first().json;\nconst existingRaw = Buffer.from(ghFile.content.replace(/\\n/g,''),'base64').toString('utf-8');\nconst existing = JSON.parse(existingRaw);\nconst existingIds = new Set(existing.map(r=>r._place_id).filter(Boolean));\nconst toAdd = batch.listings.filter(r=>r._place_id&&!existingIds.has(r._place_id));\nconst merged = [...existing, ...toAdd];\nconst encoded = Buffer.from(JSON.stringify(merged,null,2)+'\\n').toString('base64');\nreturn [{ json: {\n  niche_slug: batch.niche_slug,\n  sha: ghFile.sha,\n  content: encoded,\n  added: toAdd.length,\n  total: merged.length,\n  message: 'chore(data): add '+toAdd.length+' listings to '+batch.niche_slug+'.json [n8n]'\n} }];"
      },
