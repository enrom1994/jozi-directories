    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst ctx = $('Code â€“ Get Next Pending Row').item.json;\n\n// Extract suburb from a South African address string.\n// Format: \"Street, Suburb, City, PostalCode, South Africa\"\nfunction extractSuburb(address) {\n  if (!address) return '';\n  // Strip trailing 'South Africa'\n  let s = address.replace(/,\\s*South Africa\\s*$/i, '').trim();\n  // Strip 4-digit postal code\n  s = s.replace(/,\\s*\\d{4}\\s*$/, '').trim();\n  // Split by comma â€” suburb is second-from-last segment\n  const parts = s.split(',').map(p => p.trim()).filter(Boolean);\n  if (parts.length >= 2) return parts[parts.length - 2];\n  return parts[parts.length - 1] || '';\n}\n\nreturn items.map(item => {\n  const r = item.json;\n  const website   = r.website ?? '';\n  const address   = r.address ?? '';\n  const placeId   = r.place_id ?? r.data_id ?? (String(r.title ?? '') + '_' + address);\n\n  // Build a clean, consistent Google Maps URL from the place_id.\n  // Falls back to SerpAPI's own links if no place_id available.\n  const googleMapsUrl = placeId\n    ? 'https://www.google.com/maps/place/?q=place_id:' + placeId\n    : (r.links?.directions ?? r.place_id_search ?? '');\n\n  return {\n    json: {\n      niche:           ctx.niche_name,\n      business_name:   r.title ?? '',\n      address:         address,\n      suburb:          extractSuburb(address),\n      phone:           String(r.phone ?? 'N/A'),\n      website:         website,\n      has_website:     website !== '' ? 'TRUE' : 'FALSE',\n      rating:          r.rating ?? '',\n      review_count:    r.reviews ?? 'N/A',\n      google_maps_url: googleMapsUrl,\n      scraped_at:      new Date().toISOString(),\n      // Internal deduplication key â€” not written to sheet\n      _place_id:       placeId,\n    }\n  };\n});"
      },
