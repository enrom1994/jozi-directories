      "parameters": {
        "jsCode": "const newListings = $('Code – Deduplicate by URL').all().map(i => i.json);\nconst nicheSlug = (newListings[0]?.niche ?? '')\n  .toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');\nreturn [{ json: { niche_slug: nicheSlug, listings: newListings, count: newListings.length } }];"
      },
