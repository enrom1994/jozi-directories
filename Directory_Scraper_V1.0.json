      "parameters": {
        "jsCode": "const allItems = $input.all();\n\n// Items from 'Read Existing Results' have row_number (added by n8n GSheets node).\n// Items from 'Code â€“ Extract & Map Fields' do NOT have row_number.\nconst existingUrls = new Set(\n  allItems\n    .filter(item => item.json.row_number !== undefined)\n    .map(item => String(item.json['google_maps_url'] ?? '').trim())\n    .filter(url => url !== '')\n);\n\nconst newResults = allItems.filter(item => item.json.row_number === undefined);\n\nif (newResults.length === 0) {\n  // SerpAPI returned no results for this query â€” nothing to write\n  return [];\n}\n\nreturn newResults\n  .filter(item => {\n    const url = String(item.json['google_maps_url'] ?? '').trim();\n    return url !== '' && !existingUrls.has(url);\n  })\n  .map(item => ({ json: item.json }));"
      },
