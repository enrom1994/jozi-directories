    {
      "parameters": {
        "jsCode": "// Pull all deduplicated listings and derive the niche slug.\n// Works for both webhook path (slug from payload) and manual/queue path (slug derived from niche name).\nconst newListings = $('Code – Deduplicate by URL').all().map(i => i.json);\n\nif (newListings.length === 0) {\n  // Nothing new to write to GitHub — stop this branch cleanly\n  return [];\n}\n\nconst nicheSlug = (newListings[0]?.niche ?? '')\n  .toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');\n\nreturn [{ json: { niche_slug: nicheSlug, listings: newListings, count: newListings.length } }];"
      },
      "id": "876386ad-ff7a-4cf6-9bf6-7b69e4dc9ccb",
      "name": "Code – Format Ingest Batch",
