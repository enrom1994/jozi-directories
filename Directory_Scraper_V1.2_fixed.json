        "jsCode": "const allItems = $input.all();\n\nconst existingUrls = new Set(\n  allItems\n    .filter(item => item.json.row_number !== undefined)\n    .map(item => String(item.json['google_maps_url'] ?? '').trim())\n    .filter(url => url !== '')\n);\n\nconst newResults = allItems.filter(item => item.json.row_number === undefined);\n\nif (newResults.length === 0) {\n  return [];\n}\n\nreturn newResults\n  .filter(item => {\n    const url = String(item.json['google_maps_url'] ?? '').trim();\n    return url !== '' && !existingUrls.has(url);\n  })\n  .map(item => ({ json: item.json }));"
