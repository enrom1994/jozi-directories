      "parameters": {
        "jsCode": "const allRows = $input.all();\n\n// Find first row where status is exactly 'pending'\nconst pending = allRows.find(item => {\n  const status = String(item.json['status'] ?? '').trim().toLowerCase();\n  return status === 'pending';\n});\n\nif (!pending) {\n  throw new Error('No pending rows in Scrape Queue. All rows are done or errored.');\n}\n\nconst row = pending.json;\n\n// Generate niche_slug here so both paths produce it\nconst nicheSlug = String(row['niche_name'] ?? '').trim()\n  .toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');\n\nreturn [{\n  json: {\n    niche_name:  String(row['niche_name']  ?? '').trim(),\n    niche_slug:  nicheSlug,\n    search_term: String(row['search_term'] ?? '').trim(),\n    location:    String(row['location']    ?? '').trim(),\n    row_number:  row['row_number'],\n    serpApiKey:  $env.SERP_API_KEY,\n  }\n}];"
      },
