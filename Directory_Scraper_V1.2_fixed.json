    {
      "parameters": {
        "jsCode": "const batch = $('Code – Format Ingest Batch').first().json;\nconst ghFile = $input.first().json;\n\n// Handle first-ever write (file doesn't exist yet — GET returned 404)\nlet existing = [];\nlet sha = null;\nif (ghFile.content) {\n  try {\n    const existingRaw = Buffer.from(ghFile.content.replace(/\\n/g, ''), 'base64').toString('utf-8');\n    existing = JSON.parse(existingRaw);\n    sha = ghFile.sha ?? null;\n  } catch(e) {\n    existing = [];\n    sha = null;\n  }\n}\n\nconst existingIds = new Set(existing.map(r => r._place_id).filter(Boolean));\nconst toAdd = batch.listings.filter(r => r._place_id && !existingIds.has(r._place_id));\nconst merged = [...existing, ...toAdd];\nconst encoded = Buffer.from(JSON.stringify(merged, null, 2) + '\\n').toString('base64');\n\nreturn [{ json: {\n  niche_slug: batch.niche_slug,\n  sha:        sha,\n  content:    encoded,\n  added:      toAdd.length,\n  total:      merged.length,\n  message:    'chore(data): add ' + toAdd.length + ' listings to ' + batch.niche_slug + '.json [n8n]'\n} }];"
      },
