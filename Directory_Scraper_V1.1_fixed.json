    {
      "parameters": {
        "url": "={{ 'https://api.github.com/repos/' + $vars.GITHUB_REPO + '/contents/data/' + $json.niche_slug + '.json' }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization",       "value": "={{ 'Bearer ' + $vars.GITHUB_TOKEN }}" },
            { "name": "Accept",              "value": "application/vnd.github+json" },
