      "parameters": {
        "jsCode": "// Dual-path: only fires in manual/queue mode where a row_number exists.\n// In webhook mode, Code – Get Next Pending Row never ran, so return [] to skip.\nlet row_number;\ntry {\n  row_number = $('Code – Get Next Pending Row').first()?.json?.row_number;\n} catch(e) {\n  // Webhook path – no queue row to mark done\n  return [];\n}\nif (!row_number) return [];\nreturn [{\n  json: {\n    row_number,\n    scraped_at: new Date().toISOString(),\n    status:     'done'\n  }\n}];"
