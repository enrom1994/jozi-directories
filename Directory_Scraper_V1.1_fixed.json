        "jsCode": "// Router: normalise input from either trigger.\n// Webhook payload: { niche_name, niche_slug, search_term, location }\n// Manual/Queue path: data already handled by 'Code – Get Next Pending Row'\nconst body = $input.first()?.json?.body ?? $input.first()?.json ?? {};\nreturn [{\n  json: {\n    niche_name:  String(body.niche_name  ?? '').trim(),\n    niche_slug:  String(body.niche_slug  ?? '').trim(),\n    search_term: String(body.search_term ?? '').trim(),\n    location:    String(body.location    ?? '').trim(),\n    serpApiKey:  $vars.SERP_API_KEY,\n  }\n}];"
