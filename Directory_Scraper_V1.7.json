    {
      "parameters": {
        "url": "={{ 'https://api.github.com/repos/' + $json.githubRepo + '/contents/data/' + $json.niche_slug + '.json' }}",
        "sendHeaders": true,
        "headerParameters": { "parameters": [
          { "name": "Authorization",        "value": "={{ 'Bearer ' + $json.githubToken }}" },
          { "name": "Accept",               "value": "application/vnd.github+json" },
          { "name": "X-GitHub-Api-Version", "value": "2022-11-28" }
        ]},
