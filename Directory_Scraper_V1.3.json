        "jsCode": "const allItems = $input.all();\nconst existingUrls = new Set(\n  allItems.filter(item => item.json.row_number !== undefined)\n    .map(item => String(item.json['google_maps_url'] ?? '').trim()).filter(url => url !== '')\n);\nconst newResults = allItems.filter(item => item.json.row_number === undefined);\nif (newResults.length === 0) return [];\nreturn newResults.filter(item => {\n  const url = String(item.json['google_maps_url'] ?? '').trim();\n  return url !== '' && !existingUrls.has(url);\n}).map(item => ({ json: item.json }));"
