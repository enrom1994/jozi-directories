    {
      "parameters": {
        "jsCode": "const items = $input.all();\nlet ctx = {};\ntry { ctx = $('Code \u2013 Get Next Pending Row').first().json; } catch(e) {}\nif (!ctx.niche_name) {\n  try { ctx = $('Code \u2013 Normalise Webhook Input').first().json; } catch(e) {}\n}\n\nfunction extractSuburb(address) {\n  if (!address) return '';\n  let s = address.replace(/,\\s*South Africa\\s*$/i, '').trim();\n  s = s.replace(/,\\s*\\d{4}\\s*$/, '').trim();\n  const parts = s.split(',').map(p => p.trim()).filter(Boolean);\n  if (parts.length >= 2) return parts[parts.length - 2];\n  return parts[parts.length - 1] || '';\n}\n\nreturn items.map(item => {\n  const r = item.json;\n  const website = r.website ?? '';\n  const address = r.address ?? '';\n  const placeId = r.place_id ?? r.data_id ?? (String(r.title ?? '') + '_' + address);\n  const googleMapsUrl = placeId ? 'https://www.google.com/maps/place/?q=place_id:' + placeId : '';\n  return { json: {\n    niche:           ctx.niche_name,\n    business_name:   r.title ?? '',\n    address,\n    suburb:          extractSuburb(address),\n    phone:           String(r.phone ?? 'N/A'),\n    website,\n    has_website:     website !== '' ? 'TRUE' : 'FALSE',\n    rating:          r.rating ?? '',\n    review_count:    r.reviews ?? 'N/A',\n    google_maps_url: googleMapsUrl,\n    scraped_at:      new Date().toISOString(),\n    _place_id:       placeId,\n  } };\n});"
      },
